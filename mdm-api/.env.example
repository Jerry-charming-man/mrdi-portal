# mdm-api — 环境变量
# 复制到 .env 后按需修改

NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# PostgreSQL — schema=mdm（docker-compose init 脚本已自动建好）
DATABASE_URL=postgresql://mrdi:mrdi_dev@localhost:5432/mrdi?schema=mdm

# JWT
JWT_SECRET=dev-jwt-secret-change-in-production-mrdi-2026
JWT_EXPIRES_IN=8h

# Dev login（仅 NODE_ENV=development 有效）
DEV_LOGIN_ENABLED=true

# ADMIN_KEY: 保护 dev_login 的额外密钥；留空则允许无条件 dev_login（向后兼容）
ADMIN_KEY=

# M365 OAuth mock（dev only；T3 · ADR-0006）；留空则默认 true（NODE_ENV=development）
M365_MOCK_ENABLED=true

# CORS
CORS_ORIGINS=http://localhost:8089,http://localhost:5173
