{
  "name": "mdm-api",
  "version": "1.0.0",
  "private": true,
  "description": "MRDI MDM — Master Data Management + Permission Authority API",
  "type": "module",
  "scripts": {
    "dev": "pnpm exec tsx watch src/server.ts",
    "start": "node dist/src/server.js",
    "build": "pnpm exec tsc -p tsconfig.json",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit",
    "db:generate": "pnpm exec prisma generate",
    "db:migrate": "pnpm exec prisma migrate dev",
    "db:push": "pnpm exec prisma db push --skip-generate",
    "db:seed": "pnpm exec tsx prisma/seed.ts",
    "db:studio": "pnpm exec prisma studio",
    "clean": "rm -rf dist prisma/*.sql"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/swagger": "^8.0.0",
    "@fastify/swagger-ui": "^4.0.0",
    "@mrdi/shared": "workspace:*",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.30.0",
    "fastify": "^4.28.0",
    "fastify-plugin": "^4.5.1",
    "http-errors": "^2.0.1",
    "ioredis": "^5.4.1",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/http-errors": "^2.0.5",
    "@types/node": "^20.19.43",
    "prisma": "^5.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
