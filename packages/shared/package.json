{
  "name": "@mrdi/shared",
  "version": "1.0.0",
  "private": true,
  "description": "Shared types, errors, validators, and utilities across MRDI business services",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js"
    },
    "./duration": {
      "types": "./dist/duration/index.d.ts",
      "import": "./dist/duration/index.js"
    },
    "./enums": {
      "types": "./dist/enums/index.d.ts",
      "import": "./dist/enums/index.js"
    },
    "./mdm-client": {
      "types": "./dist/mdm-client/index.d.ts",
      "import": "./dist/mdm-client/index.js"
    },
    "./request-no": {
      "types": "./dist/request-no/index.d.ts",
      "import": "./dist/request-no/index.js"
    },
    "./permission": {
      "types": "./dist/permission/index.d.ts",
      "import": "./dist/permission/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "../../node_modules/.bin/tsc -p tsconfig.json",
    "dev": "../../node_modules/.bin/tsc -p tsconfig.json --watch",
    "typecheck": "../../node_modules/.bin/tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "typescript": "^5.5.0"
  }
}
