{
  "name": "@mrdi/ui",
  "version": "1.0.0",
  "private": true,
  "description": "Shared React UI components (Button/Input/Modal/...) and Tailwind preset across MRDI frontends",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./tailwind-preset": "./tailwind-preset.cjs",
    "./components/*": "./src/components/*"
  },
  "files": [
    "src",
    "tailwind-preset.cjs"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo 'no lint configured yet'"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "tailwindcss": "^3.4.0"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "clsx": "^2.1.0",
    "lucide-react": "^0.400.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.5.0"
  }
}
