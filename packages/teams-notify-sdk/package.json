{
  "name": "@mrdi/teams-notify",
  "version": "1.0.0",
  "private": true,
  "description": "MRDI Teams Notify Gateway SDK — send Adaptive Card notifications to Teams from business systems",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./templates": {
      "types": "./dist/templates/index.d.ts",
      "import": "./dist/templates/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "Remove-Item -Recurse -Force dist, *.tsbuildinfo"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "fastify": "^4.28.0"
  }
}
