# ===== PostgreSQL =====
# 默认用 docker-compose 起的本地 PG（端口 5432）
DATABASE_URL=postgresql://mrdi:mrdi_dev@localhost:5432/mrdi?schema=public

# 每个服务单独 schema，复制时替换 schema=
# MDM_URL=postgresql://mrdi:mrdi_dev@localhost:5432/mrdi?schema=mdm
# CIMRMS_URL=postgresql://mrdi:mrdi_dev@localhost:5432/mrdi?schema=cimrms
# CIMIMS_URL=postgresql://mrdi:mrdi_dev@localhost:5432/mrdi?schema=cimims
# PERM_URL=postgresql://mrdi:mrdi_dev@localhost:5432/mrdi?schema=cimperm

# ===== Redis =====
REDIS_URL=redis://localhost:6379/0
REDIS_KEYSPACE=mrdi:

# ===== JWT =====
JWT_SECRET=change-me-in-prod-mrdi-2026
JWT_EXPIRES_IN=8h

# ===== MDM (权限中心) =====
# 业务系统通过 MDM_BASE_URL 调 MDM，所有调用必须带 X-API-Key
MDM_BASE_URL=http://localhost:3000/mdm-api/v1
MDM_API_KEY=dev-key-replace-in-prod
MDM_TIMEOUT_MS=3000
MDM_CACHE_TTL_S=300

# ===== M365 SSO (生产用) =====
# M365_TENANT_ID=
# M365_CLIENT_ID=
# M365_CLIENT_SECRET=
# M365_REDIRECT_URI=http://localhost:8089/auth/callback
DEV_LOGIN_ENABLED=true

# ===== Service 端口 =====
PORT=3000
LOG_LEVEL=info
NODE_ENV=development

# ===== SMTP (内网) =====
SMTP_HOST=smtp.internal
SMTP_PORT=25
SMTP_FROM=noreply@mrdi.local
# dev 模式下邮件走 console，不需真实 SMTP
