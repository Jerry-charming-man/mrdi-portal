# cimrms-api — 环境变量
# 复制到 .env 后按需修改

NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# PostgreSQL — schema=cimrms（docker-compose init 脚本已自动建好）
DATABASE_URL=postgresql://mrdi:mrdi_dev@localhost:5432/mrdi?schema=cimrms

# JWT
JWT_SECRET=dev-jwt-secret-change-in-production-mrdi-2026
JWT_EXPIRES_IN=8h

# Dev login（仅 NODE_ENV=development 有效）
DEV_LOGIN_ENABLED=true

# CORS
CORS_ORIGINS=http://localhost:8089,http://localhost:5173

# MDM 集成
MDM_BASE_URL=http://localhost:3000/mdm-api/v1
MDM_TIMEOUT_MS=3000
