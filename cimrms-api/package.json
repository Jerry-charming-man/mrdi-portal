{
  "name": "cimrms-api",
  "version": "1.0.0",
  "private": true,
  "description": "MRDI CIM-RMS — Requirement Management API",
  "type": "module",
  "scripts": {
    "dev": "pnpm exec tsx watch src/server.ts",
    "start": "node --env-file=.env dist/server.js",
    "build": "pnpm exec tsc -p tsconfig.json",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit",
    "db:generate": "pnpm exec prisma generate",
    "db:push": "pnpm exec prisma db push --skip-generate",
    "clean": "rm -rf dist prisma/*.sql"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/swagger": "^8.0.0",
    "@fastify/swagger-ui": "^4.0.0",
    "@fastify/websocket": "^11.3.0",
    "@mrdi/shared": "workspace:*",
    "@mrdi/teams-notify": "workspace:*",
    "@prisma/client": "^5.22.0",
    "fastify": "^4.28.0",
    "fastify-plugin": "^4.5.1",
    "http-errors": "^2.0.1",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/http-errors": "^2.0.5",
    "@types/node": "^20.19.43",
    "prisma": "^5.21.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
