{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "paths": {
      "@prisma/client": ["./node_modules/.prisma/cimims-client"],
      "@mrdi/shared": ["../packages/shared/dist"],
      "@mrdi/shared/*": ["../packages/shared/dist/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
