# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cim_perm
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cim_perm
DB_USER=postgres
DB_PASSWORD=postgres

# Auth (M365 / Entra ID)
JWT_AUDIENCE=https://mrdi.example/cim-perm
JWT_ISSUER=https://login.microsoftonline.com/{TENANT_ID}/v2.0
JWT_JWKS_URI=https://login.microsoftonline.com/{TENANT_ID}/discovery/v2.0/keys

# MDM API (internal microservice)
MDM_API_BASE=http://localhost:3001/mdm-api/v1
MDM_API_KEY=dev-key-change-in-production

# App
PORT=3001
NODE_ENV=development
