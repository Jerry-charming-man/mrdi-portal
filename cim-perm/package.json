{
  "name": "cim-perm-api",
  "version": "1.0.0",
  "private": true,
  "description": "MRDI CIM-PERM — Permission Request Management API (migrated from Express to Fastify 4)",
  "type": "module",
  "scripts": {
    "dev": "pnpm exec tsx watch src/server.ts",
    "start": "node --env-file=.env dist/server.js",
    "build": "pnpm exec tsc -p tsconfig.json",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit",
    "db:migrate": "pnpm exec tsx src/db/migrate.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/swagger": "^8.0.0",
    "@fastify/swagger-ui": "^4.0.0",
    "@mrdi/shared": "workspace:*",
    "@prisma/client": "5.22.0",
    "fastify": "^4.28.0",
    "fastify-plugin": "^4.5.1",
    "http-errors": "^2.0.1",
    "node-cron": "^3.0.3",
    "pg": "^8.12.0",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/http-errors": "^2.0.5",
    "@types/node": "^20.19.43",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
